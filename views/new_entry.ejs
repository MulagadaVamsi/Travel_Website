<%layout("./layouts/boilerplate")%>
<body>
    <div class="row mt-2">
        <div class="col-8 offset-2">
    <h3>Adding new listing</h3>
    <form method="post" action="/listings">
        <div class="mg-3">
            <label for="title" class="form-label">Title</label>
            <input placeholder="Enter the Title" name="title" class="form-control">
        </div>
        <div class="mg-3">
           <label for="description" class="form-label">Description</label>
            <textarea placeholder="Enter the description" name="description" class="form-control"></textarea>
        </div>
        <div class="mg-3">
            <label for="image" class="form-label">Image</label>
            <input placeholder="Paste the url/link" name="image" class="form-control">
        </div>
        <div class="row">
            <div class="mg-3 col-md-4">
            <label for="price" class="form-label">Price</label>
            <input placeholder="Enter the Price" name="price" class="form-control" type="number">
        </div>
        <div class="mg-3 col-md-8">
            <label for="location" class="form-label">location</label>
            <input placeholder="Enter the location" name="location" class="form-control">
        </div>
        </div>
        <div class="mg-3 col-8">
            <label for="country" class="form-label">Country</label>
            <input placeholder="Enter the Country" name="country" class="form-control">
        </div>
        <br>
        <form method="post" action="/listings">
            <button class="btn btn-dark add-btn">Add</button>
        </form>
        <br><br>
    </form>
    </div>
    </div>
</body>